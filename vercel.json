{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/awal.html" },
    { "source": "/login.php", "destination": "/api/service/login.php" },
    { "source": "/beranda.php", "destination": "/api/service/beranda.php" },
    { "source": "/prosesLogin.php", "destination": "/api/Proses/prosesLogin.php" }
  ]
}