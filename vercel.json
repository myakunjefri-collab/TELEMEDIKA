{
  "builds": [
    {
      "src": "api/**/*.php",
      "use": "vercel-php@0.7.1"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/awal.html" },
    { "src": "/login.php", "dest": "/api/service/login.php" },
    { "src": "/beranda.php", "dest": "/api/service/beranda.php" },
    { "src": "/prosesLogin.php", "dest": "/api/Proses/prosesLogin.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}